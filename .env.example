# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored; .env.example is the committed template.

# Neon Postgres pooled connection string for the development branch.
# Used by the app at runtime and by `bun db:migrate` / `bun db:push`.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Neon Postgres pooled connection string for the production branch.
# Only needed to run `bun db:migrate:prod` from your machine before a release;
# the deployed app reads DATABASE_URL (set in Vercel) at runtime.
DATABASE_URL_PROD=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Identify this app to AniList in the User-Agent header. Replace <you> with your GitHub handle.
ANILIST_USER_AGENT=whatnow.moe (https://github.com/<you>/whatnow-moe)
